# === Claude (runtime: Orquestador y Edge Functions) ===
ANTHROPIC_API_KEY=

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Token de la CLI de Supabase. Lo usan deploy.sh y el CI de GitHub para desplegar Edge Functions.
SUPABASE_ACCESS_TOKEN=

# === Lovable MCP (HTTP, OAuth con auto-refresco) ===
# El Orquestador habla con el MCP de Lovable por HTTP usando tokens OAuth que se auto-refrescan.
# Genéralos UNA VEZ con `npm run auth` en orquestador/. Requiere plan de pago de Lovable (Pro/Business).
LOVABLE_ACCESS_TOKEN=
LOVABLE_REFRESH_TOKEN=
LOVABLE_WORKSPACE_ID=        # workspace donde crear los proyectos (si se omite, usa el primero)
# LOVABLE_TIMEOUT_MS=900000  # tiempo máx. por build (15 min)

# === Email (Resend, dominio secundario) ===
RESEND_API_KEY=
FROM_EMAIL=hola@trywebforge-mail.com

# === Pagos (Stripe) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Facturación (Holded) ===
# Al cobrar crea contacto + factura BORRADOR (nunca la emite ni la cobra). Si se omite, se salta Holded.
HOLDED_API_KEY=

# === Scraper (Apify) ===
# OJO: run-scrape (Edge) y deploy.sh leen APIFY_TOKEN_2. El Orquestador (reviews.ts) acepta APIFY_TOKEN o APIFY_TOKEN_2.
# Rellena APIFY_TOKEN_2 (y APIFY_TOKEN si usas el orquestador) o el scraper devolverá 500 "Falta APIFY_TOKEN_2".
APIFY_TOKEN=
APIFY_TOKEN_2=
INGEST_WEBHOOK_SECRET=

# === LinkedIn (B2B) ===
# Outreach semi-manual: NO requiere claves. Claude redacta el mensaje y tú lo copias/pegas.

# === Orquestador ===
BATCH_SIZE=5
BOOKING_BASE=https://app.webforge.io/book
# URL pública del panel (redirects de Stripe checkout y enlaces de email). deploy.sh la sube como secret.
APP_URL=
ORQUESTADOR_MODEL=claude-sonnet-4-6  # modelo en runtime (Sonnet 4.6). Haiku 4.5 para extracción a volumen.
# LEAD_ID=                           # procesar SOLO este lead (opcional; equivale a --lead <id>)
