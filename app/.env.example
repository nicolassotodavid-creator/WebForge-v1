# === WebForge · variables PÚBLICAS del frontend (Vite) ===
# Son seguras para el navegador: la URL del proyecto y la "anon key" (protegida por RLS).
# NUNCA pongas aquí la service role key ni ningún secret de servidor.
#
# Cómo usarlo: copia este archivo a app/.env.local y pega tus valores.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Email del admin (David). Decide qué ve en el panel: solo el admin ve la
# construcción de webs (brief, construir, QA). Cualquier otro usuario = Luvia.
VITE_ADMIN_EMAIL=nicolassotodavid@gmail.com
