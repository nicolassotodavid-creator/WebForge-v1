# === Claude (runtime: Orquestador y Edge Functions) ===
ANTHROPIC_API_KEY=

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Lovable MCP (vía Claude Code, OAuth) ===
# El MCP de Lovable usa OAuth, NO una key plana. Conéctalo UNA VEZ con Claude Code:
#   claude mcp add --scope user --transport http lovable "https://mcp.lovable.dev"
# Requiere plan de pago de Lovable (Pro/Business). Variables opcionales del puente:
# LOVABLE_WORKSPACE_ID=      # workspace donde crear los proyectos (si se omite, usa el primero)
# LOVABLE_MCP_NAME=lovable   # nombre con el que añadiste el MCP en Claude Code
# CLAUDE_BIN=claude          # ruta al binario de Claude Code
# LOVABLE_TIMEOUT_MS=900000  # tiempo máx. por build (15 min)

# === Email (Resend, dominio secundario) ===
RESEND_API_KEY=
FROM_EMAIL=hola@trywebforge-mail.com

# === Pagos (Stripe) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === Scraper ===
# OJO: la Edge Function run-scrape y deploy.sh leen APIFY_TOKEN_2 (no APIFY_TOKEN).
# Rellena APIFY_TOKEN_2 o el scraper de Google Maps devolverá 500 "Falta APIFY_TOKEN_2".
APIFY_TOKEN_2=
INGEST_WEBHOOK_SECRET=

# === LinkedIn (B2B) ===
# Outreach semi-manual: NO requiere claves. Claude redacta el mensaje y tú lo copias/pegas.

# === Orquestador ===
BATCH_SIZE=5
BOOKING_BASE=https://app.webforge.io/book
# ORQUESTADOR_MODEL=claude-fable-5   # modelo de Fable en runtime (opcional)
# LEAD_ID=                           # procesar SOLO este lead (opcional; equivale a --lead <id>)
